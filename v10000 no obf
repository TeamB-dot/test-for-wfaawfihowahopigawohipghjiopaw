			-- COLORPICKER
			function EF:AddColorpicker(ccfg)
				ccfg=ccfg or {}; ccfg.Name=ccfg.Name or "Color"
				ccfg.Default=ccfg.Default or Color3.fromRGB(255,255,255)
				ccfg.Callback=ccfg.Callback or function()end
				ccfg.Flag=ccfg.Flag or nil; ccfg.Save=ccfg.Save or false
				local ch,cs,cv=Color3.toHSV(ccfg.Default)
				local CP={Value=ccfg.Default,Toggled=false,Type="Colorpicker",Save=ccfg.Save}
				local outer=N("Frame",{
					Size=UDim2.new(1,0,0,30), BackgroundColor3=C.Card,
					BorderSizePixel=0, ClipsDescendants=true, Parent=host,
				},{Stroke(C.Border,1)})
				local hdr=N("Frame",{Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,Parent=outer})
				local hdrBtn=Btn(); hdrBtn.Parent=hdr
				local hl2=Lbl(ccfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				hl2.Size=UDim2.new(1,-40,1,0); hl2.Position=UDim2.new(0,10,0,0); hl2.Parent=hdr
				local prev=N("Frame",{
					Size=UDim2.new(0,16,0,16), Position=UDim2.new(1,-10,0.5,0), AnchorPoint=Vector2.new(1,0.5),
					BackgroundColor3=ccfg.Default, BorderSizePixel=0, Parent=hdr,
				},{Stroke(C.Border,1)})
				N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,29),BackgroundColor3=C.Border,BorderSizePixel=0,Visible=false,Name="Line",Parent=outer})
				local panel=N("Frame",{Size=UDim2.new(1,0,0,94),Position=UDim2.new(0,0,0,30),BackgroundTransparency=1,Parent=outer},{Pad(6,8,8,6)})
				local cbox=N("ImageLabel",{Size=UDim2.new(1,-18,1,0),Image="rbxassetid://4155801252",BackgroundColor3=Color3.fromHSV(ch,1,1),Parent=panel})
				local cSel=N("ImageLabel",{Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(cs,0,1-cv,0),Image="http://www.roblox.com/asset/?id=4805639000",BackgroundTransparency=1,Parent=cbox})
				local hbar=N("Frame",{Size=UDim2.new(0,10,1,0),Position=UDim2.new(1,-10,0,0),Parent=panel},{N("UIGradient",{Rotation=270,Color=ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(255,0,4)),ColorSequenceKeypoint.new(0.2,Color3.fromRGB(234,255,0)),ColorSequenceKeypoint.new(0.4,Color3.fromRGB(21,255,0)),ColorSequenceKeypoint.new(0.6,Color3.fromRGB(0,255,255)),ColorSequenceKeypoint.new(0.8,Color3.fromRGB(0,17,255)),ColorSequenceKeypoint.new(0.9,Color3.fromRGB(255,0,251)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,0,4))}})})
				local hSel=N("ImageLabel",{Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,1-ch,0),Image="http://www.roblox.com/asset/?id=4805639000",BackgroundTransparency=1,Parent=hbar})
				local function UpdCP()
					local col=Color3.fromHSV(ch,cs,cv)
					prev.BackgroundColor3=col; cbox.BackgroundColor3=Color3.fromHSV(ch,1,1)
					CP.Value=col; ccfg.Callback(col); SaveFlag(game.GameId)
				end
				local cc2,hc2
				Conn(cbox.InputBegan,function(i)
					if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
					if cc2 then cc2:Disconnect() end
					cc2=Conn(Run.RenderStepped,function()
						cs=math.clamp((Mouse.X-cbox.AbsolutePosition.X)/cbox.AbsoluteSize.X,0,1)
						cv=1-math.clamp((Mouse.Y-cbox.AbsolutePosition.Y)/cbox.AbsoluteSize.Y,0,1)
						cSel.Position=UDim2.new(cs,0,1-cv,0); UpdCP()
					end)
				end)
				Conn(cbox.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 and cc2 then cc2:Disconnect() end end)
				Conn(hbar.InputBegan,function(i)
					if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
					if hc2 then hc2:Disconnect() end
					hc2=Conn(Run.RenderStepped,function()
						local y=math.clamp((Mouse.Y-hbar.AbsolutePosition.Y)/hbar.AbsoluteSize.Y,0,1)
						hSel.Position=UDim2.new(0.5,0,y,0); ch=1-y; UpdCP()
					end)
				end)
				Conn(hbar.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 and hc2 then hc2:Disconnect() end end)
				Conn(hdrBtn.MouseButton1Click,function()
					CP.Toggled=not CP.Toggled
					outer:FindFirstChild("Line").Visible=CP.Toggled
					Tw(outer,0.12,{Size=UDim2.new(1,0,0,CP.Toggled and 124 or 30)})
				end)
				function CP:Set(v)
					self.Value=v; ch,cs,cv=Color3.toHSV(v)
					prev.BackgroundColor3=v; cbox.BackgroundColor3=Color3.fromHSV(ch,1,1)
					cSel.Position=UDim2.new(cs,0,1-cv,0); hSel.Position=UDim2.new(0.5,0,1-ch,0)
					ccfg.Callback(v)
				end
				CP:Set(CP.Value)
				if ccfg.Flag then Lib.Flags[ccfg.Flag]=CP end
				return CP
			end

			return EF
		end -- BuildEF

		-- section wrapper
		local RootEF={}
		function RootEF:AddSection(scfg)
			scfg=scfg or {}; scfg.Name=scfg.Name or "Section"
			local sec=N("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Parent=content})
			local sl2=Lbl(scfg.Name:upper(),9,C.Dim,Enum.Font.GothamBold)
			sl2.Size=UDim2.new(1,0,0,9); sl2.Position=UDim2.new(0,2,0,2); sl2.Parent=sec
			N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,15),BackgroundColor3=C.Div,BorderSizePixel=0,Parent=sec})
			local holder=N("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,20),BackgroundTransparency=1,Name="H",Parent=sec},{List(3)})
			Conn(holder.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
				holder.Size=UDim2.new(1,0,0,holder.UIListLayout.AbsoluteContentSize.Y)
				sec.Size=UDim2.new(1,0,0,holder.UIListLayout.AbsoluteContentSize.Y+22)
			end)
			local SF={}
			for k,v in next,BuildEF(holder) do SF[k]=v end
			return SF
		end
		for k,v in next,BuildEF(content) do RootEF[k]=v end

		if tabCfg.PremiumOnly then
			for k in next,RootEF do RootEF[k]=function()end end
			content:ClearAllChildren()
			local g=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Parent=content})
			local gl=Lbl("Premium only",12,C.Muted,Enum.Font.GothamBold)
			gl.Size=UDim2.new(1,-20,0,12); gl.Position=UDim2.new(0,10,0,10); gl.Parent=g
			local gl2=Lbl("Join .gg/blackair for access.",11,C.Dim,Enum.Font.Gotham)
			gl2.Size=UDim2.new(1,-20,0,0); gl2.Position=UDim2.new(0,10,0,26)
			gl2.AutomaticSize=Enum.AutomaticSize.Y; gl2.TextWrapped=true; gl2.Parent=g
		end

		return RootEF
	end -- MakeTab

	return TabAPI
end -- MakeWindow

function Lib:Destroy() Root:Destroy() end

