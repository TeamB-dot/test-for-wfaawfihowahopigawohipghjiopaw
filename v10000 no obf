		local function BuildEF(host)
			local EF = {}

			-- LABEL
			function EF:AddLabel(text, icon)
				local hasIco = icon and icon ~= ""
				local xOff   = hasIco and 34 or 10
				local f = Card(host, 28)
				local l = Lbl(text or "Label", 12, C.Text, Enum.Font.GothamSemibold)
				l.Size=UDim2.new(1,-(xOff+6),1,0); l.Position=UDim2.new(0,xOff,0,0)
				l.Name="Lbl"; l.Parent=f
				if hasIco then
					N("ImageLabel",{
						Size=UDim2.new(0,12,0,12), AnchorPoint=Vector2.new(0,0.5),
						Position=UDim2.new(0,10,0.5,0), Image=icon,
						ImageColor3=C.Muted, BackgroundTransparency=1, Parent=f,
					})
				end
				local api={}
				function api:Set(v) f.Lbl.Text=tostring(v) end
				return api
			end

			-- PARAGRAPH
			function EF:AddParagraph(title, body)
				title=title or "Title"; body=body or ""
				local f = N("Frame",{
					Size=UDim2.new(1,0,0,28), BackgroundColor3=C.Card,
					BorderSizePixel=0, Parent=host,
				},{Stroke(C.Border,1)})
				local tl=Lbl(title,12,C.Text,Enum.Font.GothamBold)
				tl.Size=UDim2.new(1,-20,0,12); tl.Position=UDim2.new(0,10,0,8); tl.Parent=f
				local bl=Lbl("",11,C.Muted,Enum.Font.Gotham)
				bl.Size=UDim2.new(1,-20,0,0); bl.Position=UDim2.new(0,10,0,24)
				bl.AutomaticSize=Enum.AutomaticSize.Y; bl.TextWrapped=true; bl.Name="Body"; bl.Parent=f
				Conn(bl:GetPropertyChangedSignal("Text"),function()
					f.Size=UDim2.new(1,0,0,bl.TextBounds.Y+30)
				end)
				bl.Text=body
				local api={}
				function api:Set(v) f.Body.Text=tostring(v) end
				return api
			end

			-- BUTTON
			function EF:AddButton(bcfg)
				bcfg=bcfg or {}
				bcfg.Name=bcfg.Name or "Button"
				bcfg.Callback=bcfg.Callback or function()end
				bcfg.Icon=bcfg.Icon or ""
				local f=Card(host,30)
				local btn=Btn(); btn.Parent=f
				local l=Lbl(bcfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				l.Size=UDim2.new(1,-30,1,0); l.Position=UDim2.new(0,10,0,0)
				l.Name="Lbl"; l.Parent=f
				if bcfg.Icon~="" then
					N("ImageLabel",{
						Size=UDim2.new(0,11,0,11), Position=UDim2.new(1,-20,0.5,-5),
						Image=bcfg.Icon, ImageColor3=C.Dim, BackgroundTransparency=1, Parent=f,
					})
				end
				Conn(btn.MouseEnter,      function() HOn(f) end)
				Conn(btn.MouseLeave,      function() HOff(f) end)
				Conn(btn.MouseButton1Down,function() HPrs(f) end)
				Conn(btn.MouseButton1Up,  function() HOn(f); task.spawn(bcfg.Callback) end)
				local api={}
				function api:Set(v) f.Lbl.Text=tostring(v) end
				return api
			end

			-- TOGGLE
			function EF:AddToggle(tcfg)
				tcfg=tcfg or {}
				tcfg.Name=tcfg.Name or "Toggle"
				tcfg.Default=tcfg.Default~=nil and tcfg.Default or false
				tcfg.Callback=tcfg.Callback or function()end
				tcfg.Flag=tcfg.Flag or nil
				tcfg.Save=tcfg.Save or false
				local Toggle={Value=tcfg.Default,Save=tcfg.Save,Type="Toggle"}
				local f=Card(host,30)
				local btn=Btn(); btn.Parent=f
				local l=Lbl(tcfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				l.Size=UDim2.new(1,-56,1,0); l.Position=UDim2.new(0,10,0,0); l.Parent=f

				-- sharp pill (no corner radius = consistent with design)
				local pill=N("Frame",{
					Size=UDim2.new(0,30,0,14),
					Position=UDim2.new(1,-10,0.5,0), AnchorPoint=Vector2.new(1,0.5),
					BackgroundColor3=C.PillOff, BorderSizePixel=0, Parent=f,
				},{Stroke(C.Border,1)})
				local knob=N("Frame",{
					Size=UDim2.new(0,8,0,8),
					Position=UDim2.new(0,3,0.5,0), AnchorPoint=Vector2.new(0,0.5),
					BackgroundColor3=C.Muted, BorderSizePixel=0, Parent=pill,
				})
				function Toggle:Set(v)
					self.Value=v
					Tw(knob,0.18,{Position=v and UDim2.new(1,-11,0.5,0) or UDim2.new(0,3,0.5,0), BackgroundColor3=v and C.Base or C.Muted})
					Tw(pill,0.18,{BackgroundColor3=v and C.PillOn or C.PillOff})
					tcfg.Callback(self.Value)
				end
				Toggle:Set(Toggle.Value)
				Conn(btn.MouseEnter,      function() HOn(f) end)
				Conn(btn.MouseLeave,      function() HOff(f) end)
				Conn(btn.MouseButton1Down,function() HPrs(f) end)
				Conn(btn.MouseButton1Up,  function() HOn(f); Toggle:Set(not Toggle.Value); SaveFlag(game.GameId) end)
				if tcfg.Flag then Lib.Flags[tcfg.Flag]=Toggle end
				return Toggle
			end

			-- SLIDER
			function EF:AddSlider(scfg)
				scfg=scfg or {}
				scfg.Name=scfg.Name or "Slider"
				scfg.Min=scfg.Min or 0; scfg.Max=scfg.Max or 100
				scfg.Increment=scfg.Increment or 1; scfg.Default=scfg.Default or 50
				scfg.Callback=scfg.Callback or function()end
				scfg.ValueName=scfg.ValueName or ""
				scfg.Flag=scfg.Flag or nil; scfg.Save=scfg.Save or false
				local Slider={Value=scfg.Default,Save=scfg.Save,Type="Slider"}
				local dragging=false
				local f=Card(host,52)
				local nl=Lbl(scfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				nl.Size=UDim2.new(1,-64,0,12); nl.Position=UDim2.new(0,10,0,7); nl.Parent=f
				local vl=Lbl("",11,C.Muted,Enum.Font.GothamBold)
				vl.Size=UDim2.new(0,54,0,12); vl.Position=UDim2.new(1,-64,0,7)
				vl.TextXAlignment=Enum.TextXAlignment.Right; vl.Name="Val"; vl.Parent=f

				local track=N("Frame",{
					Size=UDim2.new(1,-20,0,4), Position=UDim2.new(0,10,0,30),
					BackgroundColor3=C.Track, BorderSizePixel=0, Parent=f,
				},{Stroke(C.Border,1)})
				local fill=N("Frame",{
					Size=UDim2.new(0,0,1,0),
					BackgroundColor3=C.Fill, BorderSizePixel=0, Parent=track,
				})
				local handle=N("Frame",{
					Size=UDim2.new(0,9,0,9),
					AnchorPoint=Vector2.new(0.5,0.5),
					Position=UDim2.new(0,0,0.5,0),
					BackgroundColor3=C.Hi, BorderSizePixel=0, Parent=track,
				})

				function Slider:Set(v)
					self.Value=math.clamp(Rnd(v,scfg.Increment),scfg.Min,scfg.Max)
					local pct=(self.Value-scfg.Min)/(scfg.Max-scfg.Min)
					Tw(fill,0.08,{Size=UDim2.new(pct,0,1,0)})
					Tw(handle,0.08,{Position=UDim2.new(pct,0,0.5,0)})
					local txt=tostring(self.Value)
					if scfg.ValueName~="" then txt=txt.." "..scfg.ValueName end
					vl.Text=txt; scfg.Callback(self.Value)
				end
				track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
				track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
				UIS.InputChanged:Connect(function(i)
					if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
						local pct=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
						Slider:Set(scfg.Min+(scfg.Max-scfg.Min)*pct); SaveFlag(game.GameId)
					end
				end)
				Slider:Set(Slider.Value)
				if scfg.Flag then Lib.Flags[scfg.Flag]=Slider end
				return Slider
			end

			-- DROPDOWN
			function EF:AddDropdown(dcfg)
				dcfg=dcfg or {}
				dcfg.Name=dcfg.Name or "Dropdown"; dcfg.Options=dcfg.Options or {}
				dcfg.Default=dcfg.Default or ""; dcfg.Callback=dcfg.Callback or function()end
				dcfg.Flag=dcfg.Flag or nil; dcfg.Save=dcfg.Save or false
				local DD={Value=dcfg.Default,Options=dcfg.Options,Buttons={},Toggled=false,Type="Dropdown",Save=dcfg.Save}
				local maxVis=5
				if not table.find(DD.Options,DD.Value) then DD.Value="..." end

				local outer=N("Frame",{
					Size=UDim2.new(1,0,0,30), BackgroundColor3=C.Card,
					BorderSizePixel=0, ClipsDescendants=true, Parent=host,
				},{Stroke(C.Border,1)})
				local hdr=N("Frame",{Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,Parent=outer})
				local hdrBtn=Btn(); hdrBtn.Parent=hdr
				local hl=Lbl(dcfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				hl.Size=UDim2.new(0.5,0,1,0); hl.Position=UDim2.new(0,10,0,0); hl.Parent=hdr
				local sl=Lbl("...",11,C.Muted,Enum.Font.Gotham)
				sl.Size=UDim2.new(0.4,0,1,0); sl.Position=UDim2.new(0.52,0,0,0)
				sl.TextXAlignment=Enum.TextXAlignment.Right; sl.Name="Sel"; sl.Parent=hdr
				local arr=N("ImageLabel",{
					Size=UDim2.new(0,10,0,10), Position=UDim2.new(1,-18,0.5,-5),
					Image="rbxassetid://7072706796", ImageColor3=C.Dim,
					BackgroundTransparency=1, Parent=hdr,
				})
				N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,29),BackgroundColor3=C.Border,BorderSizePixel=0,Visible=false,Name="Line",Parent=outer})
				local optSc=ScF(2); optSc.Size=UDim2.new(1,0,1,-30); optSc.Position=UDim2.new(0,0,0,30); optSc.Parent=outer
				List(0).Parent=optSc; Pad(2,4,4,2).Parent=optSc
				Conn(optSc.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
					optSc.CanvasSize=UDim2.new(0,0,0,optSc.UIListLayout.AbsoluteContentSize.Y+4)
				end)

				local function AddOpts(opts)
					for _,opt in pairs(opts) do
						local ob=N("TextButton",{Size=UDim2.new(1,0,0,22),BackgroundColor3=C.Card,BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=optSc})
						local ol=Lbl(opt,11,C.Muted,Enum.Font.GothamSemibold)
						ol.Size=UDim2.new(1,-16,1,0); ol.Position=UDim2.new(0,8,0,0); ol.Name="Lbl"; ol.Parent=ob
						ob.MouseEnter:Connect(function() if DD.Value~=opt then Tw(ob,0.08,{BackgroundTransparency=0.5}) end end)
						ob.MouseLeave:Connect(function() if DD.Value~=opt then Tw(ob,0.08,{BackgroundTransparency=1}) end end)
						Conn(ob.MouseButton1Click,function() DD:Set(opt); SaveFlag(game.GameId) end)
						DD.Buttons[opt]=ob
					end
				end
				function DD:Refresh(opts,clear)
					if clear then for _,v in pairs(self.Buttons) do v:Destroy() end table.clear(self.Options) table.clear(self.Buttons) end
					self.Options=opts; AddOpts(opts)
				end
				function DD:Set(v)
					if not table.find(self.Options,v) then
						self.Value="..."; hdr.Sel.Text="..."; hdr.Sel.TextColor3=C.Muted
						for _,b in pairs(self.Buttons) do Tw(b,0.08,{BackgroundTransparency=1}) Tw(b.Lbl,0.08,{TextColor3=C.Muted}) end
						return
					end
					self.Value=v; hdr.Sel.Text=v; hdr.Sel.TextColor3=C.Text
					for _,b in pairs(self.Buttons) do Tw(b,0.08,{BackgroundTransparency=1}) Tw(b.Lbl,0.08,{TextColor3=C.Muted}) end
					if self.Buttons[v] then Tw(self.Buttons[v],0.08,{BackgroundTransparency=0}) Tw(self.Buttons[v].Lbl,0.08,{TextColor3=C.Hi}) end
					dcfg.Callback(self.Value)
				end
				Conn(hdrBtn.MouseButton1Click,function()
					DD.Toggled=not DD.Toggled
					outer:FindFirstChild("Line").Visible=DD.Toggled
					Tw(arr,0.12,{Rotation=DD.Toggled and 180 or 0})
					local h=DD.Toggled and (30+math.min(#DD.Options,maxVis)*23+4) or 30
					Tw(outer,0.12,{Size=UDim2.new(1,0,0,h)})
				end)
				DD:Refresh(DD.Options,false); DD:Set(DD.Value)
				if dcfg.Flag then Lib.Flags[dcfg.Flag]=DD end
				return DD
			end

			-- BIND
			function EF:AddBind(bcfg)
				bcfg=bcfg or {}
				bcfg.Name=bcfg.Name or "Bind"; bcfg.Default=bcfg.Default or Enum.KeyCode.Unknown
				bcfg.Hold=bcfg.Hold or false; bcfg.Callback=bcfg.Callback or function()end
				bcfg.Flag=bcfg.Flag or nil; bcfg.Save=bcfg.Save or false
				local Bind={Value=nil,Binding=false,Type="Bind",Save=bcfg.Save}
				local holding=false
				local f=Card(host,30); local btn=Btn(); btn.Parent=f
				local l=Lbl(bcfg.Name,12,C.Text,Enum.Font.GothamSemibold)
				l.Size=UDim2.new(1,-72,1,0); l.Position=UDim2.new(0,10,0,0); l.Parent=f
				local box=N("Frame",{
					Size=UDim2.new(0,24,0,16), Position=UDim2.new(1,-10,0.5,0), AnchorPoint=Vector2.new(1,0.5),
					BackgroundColor3=C.Track, BorderSizePixel=0, Parent=f,
				},{Stroke(C.Border,1)})
				local bl2=Lbl("",10,C.Text,Enum.Font.GothamBold)
				bl2.Size=UDim2.new(1,0,1,0); bl2.TextXAlignment=Enum.TextXAlignment.Center
				bl2.Name="Val"; bl2.Parent=box
				Conn(bl2:GetPropertyChangedSignal("Text"),function() Tw(box,0.12,{Size=UDim2.new(0,math.max(24,bl2.TextBounds.X+10),0,16)}) end)
				Conn(btn.InputEnded,function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1 and not Bind.Binding then
						Bind.Binding=true; box.Val.Text="..."
					end
				end)
				Conn(UIS.InputBegan,function(i)
					if UIS:GetFocusedTextBox() then return end
					if (i.KeyCode.Name==Bind.Value or i.UserInputType.Name==Bind.Value) and not Bind.Binding then
						if bcfg.Hold then holding=true; bcfg.Callback(true)
						else bcfg.Callback() end
					elseif Bind.Binding then
						local key
						pcall(function() if not Has(BL_KEYS,i.KeyCode) then key=i.KeyCode end end)
						pcall(function() if Has(WL_MOUSE,i.UserInputType) and not key then key=i.UserInputType end end)
						Bind:Set(key or Bind.Value); SaveFlag(game.GameId)
					end
				end)
				Conn(UIS.InputEnded,function(i)
					if i.KeyCode.Name==Bind.Value or i.UserInputType.Name==Bind.Value then
						if bcfg.Hold and holding then holding=false; bcfg.Callback(false) end
					end
				end)
				Conn(btn.MouseEnter,function() HOn(f) end); Conn(btn.MouseLeave,function() HOff(f) end)
				Conn(btn.MouseButton1Down,function() HPrs(f) end); Conn(btn.MouseButton1Up,function() HOn(f) end)
				function Bind:Set(k)
					self.Binding=false; self.Value=k or self.Value
					if type(self.Value)=="userdata" then self.Value=self.Value.Name end
					box.Val.Text=tostring(self.Value) or "—"
				end
				Bind:Set(bcfg.Default)
				if bcfg.Flag then Lib.Flags[bcfg.Flag]=Bind end
				return Bind
			end

			-- TEXTBOX
