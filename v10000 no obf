function Lib:Init()
	if self.SaveCfg then
		pcall(function()
			local path = self.Folder.."/"..game.GameId..".txt"
			if isfile(path) then
				LoadCfg(readfile(path))
				self:MakeNotification({Name="Config loaded",Content=game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,Time=4})
			end
		end)
	end
end

