-- ── resize helper ────────────────────────────────────────────────
-- Creates invisible resize handles on all edges + corners of `frame`.
-- minW / minH = minimum size constraints.
local function MakeResizable(frame, minW, minH)
	minW = minW or 300
	minH = minH or 200

	local GRIP = 5  -- px grab zone

	-- edge definitions: {name, cursor, anchorX, anchorY, sizeX, sizeY, posX, posY}
	local edges = {
		-- sides
		{UDim2.new(0,GRIP,0,GRIP), UDim2.new(1,-GRIP*2,0,GRIP),  "left"},
		{UDim2.new(1,-GRIP,0,GRIP),UDim2.new(0,GRIP,1,-GRIP*2),  "right"},
		{UDim2.new(0,GRIP,0,0),    UDim2.new(1,-GRIP*2,0,GRIP),  "top"},
		{UDim2.new(0,GRIP,1,-GRIP),UDim2.new(1,-GRIP*2,0,GRIP),  "bottom"},
		-- corners
		{UDim2.new(0,0,0,0),       UDim2.new(0,GRIP,0,GRIP),     "tl"},
		{UDim2.new(1,-GRIP,0,0),   UDim2.new(0,GRIP,0,GRIP),     "tr"},
		{UDim2.new(0,0,1,-GRIP),   UDim2.new(0,GRIP,0,GRIP),     "bl"},
		{UDim2.new(1,-GRIP,1,-GRIP),UDim2.new(0,GRIP,0,GRIP),    "br"},
	}

	for _, e in ipairs(edges) do
		local pos, sz, name = e[1], e[2], e[3]
		local grip = N("TextButton", {
			Position             = pos,
			Size                 = sz,
			BackgroundTransparency = 1,
			BorderSizePixel      = 0,
			Text                 = "",
			AutoButtonColor      = false,
			ZIndex               = 10,
			Name                 = "Grip_"..name,
			Parent               = frame,
		})

		local resizing = false
		local startMouse, startSize, startPos

		grip.InputBegan:Connect(function(i)
			if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
			resizing   = true
			startMouse = Vector2.new(i.Position.X, i.Position.Y)
			startSize  = Vector2.new(frame.AbsoluteSize.X, frame.AbsoluteSize.Y)
			startPos   = Vector2.new(frame.AbsolutePosition.X, frame.AbsolutePosition.Y)
		end)

		grip.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 then
				resizing = false
			end
		end)

		UIS.InputChanged:Connect(function(i)
			if not resizing then return end
			if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end

			local dx = i.Position.X - startMouse.X
			local dy = i.Position.Y - startMouse.Y

			local newW = startSize.X
			local newH = startSize.Y
			local newX = startPos.X
			local newY = startPos.Y

			if name == "right"  or name == "tr" or name == "br" then newW = startSize.X + dx end
			if name == "bottom" or name == "bl" or name == "br" then newH = startSize.Y + dy end
			if name == "left"   or name == "tl" or name == "bl" then
				newW = startSize.X - dx
				newX = startPos.X + dx
			end
			if name == "top"    or name == "tl" or name == "tr" then
				newH = startSize.Y - dy
				newY = startPos.Y + dy
			end

			newW = math.max(newW, minW)
			newH = math.max(newH, minH)

			frame.Size     = UDim2.new(0, newW, 0, newH)
			frame.Position = UDim2.new(0, newX, 0, newY)
		end)
	end
end

-- ── drag ─────────────────────────────────────────────────────────
local function MakeDrag(handle, frame)
	local drag, inp, mstart, fstart = false
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then
			drag   = true
			mstart = i.Position
			fstart = frame.Position
		end
	end)
	handle.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
	end)
	handle.InputChanged:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement then inp = i end
	end)
	UIS.InputChanged:Connect(function(i)
		if i == inp and drag then
			local d = i.Position - mstart
			frame.Position = UDim2.new(
				0, fstart.X.Offset + d.X,
				0, fstart.Y.Offset + d.Y
			)
		end
	end)
end

-- ── config ────────────────────────────────────────────────────────
local function PackCol(c)   return {R=c.R*255,G=c.G*255,B=c.B*255} end
local function UnpackCol(c) return Color3.fromRGB(c.R,c.G,c.B) end
local function Rnd(n,f)
	local r = math.floor(n/f + math.sign(n)*0.5)*f
	if r < 0 then r = r + f end
	return r
end
local BL_KEYS = {Enum.KeyCode.Unknown,Enum.KeyCode.W,Enum.KeyCode.A,Enum.KeyCode.S,Enum.KeyCode.D,Enum.KeyCode.Up,Enum.KeyCode.Left,Enum.KeyCode.Down,Enum.KeyCode.Right,Enum.KeyCode.Slash,Enum.KeyCode.Tab,Enum.KeyCode.Backspace,Enum.KeyCode.Escape}
local WL_MOUSE = {Enum.UserInputType.MouseButton1,Enum.UserInputType.MouseButton2,Enum.UserInputType.MouseButton3}
local function Has(t,v) for _,x in next,t do if x==v then return true end end end

