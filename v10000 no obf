-- ── tween ─────────────────────────────────────────────────────────
local function Tw(o, t, p, s, d)
	Tween:Create(o, TweenInfo.new(t, s or Enum.EasingStyle.Quint, d or Enum.EasingDirection.Out), p):Play()
end

-- ── instance factory ──────────────────────────────────────────────
local function N(cls, props, kids)
	local o = Instance.new(cls)
	for k, v in next, props or {} do o[k] = v end
	for _, v in next, kids  or {} do v.Parent = o end
	return o
end

