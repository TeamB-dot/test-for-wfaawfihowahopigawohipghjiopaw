	function TabAPI:MakeTab(tabCfg)
		tabCfg             = tabCfg or {}
		tabCfg.Name        = tabCfg.Name        or "Tab"
		tabCfg.Icon        = tabCfg.Icon        or ""
		tabCfg.PremiumOnly = tabCfg.PremiumOnly or false

		-- ── sidebar button ────────────────────────────────────────
		local tabBtn = N("TextButton",{
			Size=UDim2.new(1,-8,0,26),
			Position=UDim2.new(0,0,0,0),
			BackgroundColor3=C.Surface,
			BackgroundTransparency=1,
			Text="", AutoButtonColor=false,
			Parent=TabScroll,
		})

		-- 2px left border = active indicator (Blackair signature)
		local strip = N("Frame",{
			Size=UDim2.new(0,2,0.6,0),
			Position=UDim2.new(0,0,0.2,0),
			BackgroundColor3=C.Hi, BackgroundTransparency=1,
			BorderSizePixel=0, Parent=tabBtn,
		})

		local tabIco = N("ImageLabel",{
			Size=UDim2.new(0,13,0,13), AnchorPoint=Vector2.new(0,0.5),
			Position=UDim2.new(0,10,0.5,0),
			Image=tabCfg.Icon, ImageColor3=C.Dim,
			BackgroundTransparency=1, Parent=tabBtn,
		})

		local tabLbl = Lbl(tabCfg.Name, 12, C.Muted, Enum.Font.GothamSemibold)
		tabLbl.Size=UDim2.new(1,-26,1,0); tabLbl.Position=UDim2.new(0,26,0,0)
		tabLbl.Name="Lbl"; tabLbl.Parent=tabBtn

		-- ── content scroll ────────────────────────────────────────
		local content = ScF(3)
		content.Size     = UDim2.new(1,-121,1,-36)
		content.Position = UDim2.new(0,121,0,36)
		content.Parent   = Win
		content.Visible  = false
		content.Name     = "Content"
		List(4).Parent   = content
		Pad(10,8,8,10).Parent = content
		Conn(content.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
			content.CanvasSize=UDim2.new(0,0,0,content.UIListLayout.AbsoluteContentSize.Y+18)
		end)

		local function setActive(on)
			if on then
				Tw(strip, 0.18, {BackgroundTransparency=0})
				Tw(tabIco,0.18, {ImageColor3=C.Hi})
				Tw(tabLbl,0.18, {TextColor3=C.Hi, TextTransparency=0})
				tabLbl.Font = Enum.Font.GothamBold
				Tw(tabBtn, 0.18, {BackgroundTransparency=0.92})
			else
				Tw(strip, 0.18, {BackgroundTransparency=1})
				Tw(tabIco,0.18, {ImageColor3=C.Dim})
				Tw(tabLbl,0.18, {TextColor3=C.Muted, TextTransparency=0.2})
				tabLbl.Font = Enum.Font.GothamSemibold
				Tw(tabBtn, 0.18, {BackgroundTransparency=1})
			end
		end

		table.insert(tabs, {btn=tabBtn, container=content, setActive=setActive})

		if firstTab then
			firstTab = false
			setActive(true)
			content.Visible  = true
			activeContainer  = content
		end

		Conn(tabBtn.MouseButton1Click, function()
			for _, te in next, tabs do
				te.setActive(false)
				te.container.Visible = false
			end
			setActive(true)
			content.Visible = true
			activeContainer = content
		end)
		Conn(tabBtn.MouseEnter, function()
			if not content.Visible then
				Tw(tabBtn,0.12,{BackgroundTransparency=0.96})
			end
		end)
		Conn(tabBtn.MouseLeave, function()
			if not content.Visible then
				Tw(tabBtn,0.12,{BackgroundTransparency=1})
			end
		end)

		-- ═══════════════════════════════════════════════════════
