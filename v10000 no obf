function Lib:IsRunning() return Root.Parent ~= nil end

local function Conn(sig, fn)
	if not Lib:IsRunning() then return end
	local c = sig:Connect(fn)
	table.insert(Lib.Connections, c)
	return c
end
task.spawn(function()
	while Lib:IsRunning() do task.wait(1) end
	for _, c in next, Lib.Connections do pcall(function() c:Disconnect() end) end
end)

local function SaveFlag(name)
	if not Lib.SaveCfg then return end
	local data = {}
	for k,v in pairs(Lib.Flags) do
		if v.Save then data[k] = v.Type=="Colorpicker" and PackCol(v.Value) or v.Value end
	end
	pcall(function() writefile(Lib.Folder.."/"..name..".txt", Http:JSONEncode(data)) end)
end
local function LoadCfg(raw)
	local ok,data = pcall(function() return Http:JSONDecode(raw) end)
	if not ok then return end
	for k,v in pairs(data) do
		if Lib.Flags[k] then
			task.spawn(function()
				if Lib.Flags[k].Type=="Colorpicker" then Lib.Flags[k]:Set(UnpackCol(v))
				else Lib.Flags[k]:Set(v) end
			end)
		end
	end
end

