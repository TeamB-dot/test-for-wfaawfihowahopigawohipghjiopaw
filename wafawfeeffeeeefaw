			function ElementFunction:AddSlider(SliderConfig)
				SliderConfig           = SliderConfig or {}
				SliderConfig.Name      = SliderConfig.Name or "Slider"
				SliderConfig.Min       = SliderConfig.Min or 0
				SliderConfig.Max       = SliderConfig.Max or 100
				SliderConfig.Increment = SliderConfig.Increment or 1
				SliderConfig.Default   = SliderConfig.Default or 50
				SliderConfig.Callback  = SliderConfig.Callback or function() end
				SliderConfig.ValueName = SliderConfig.ValueName or ""
				SliderConfig.Flag      = SliderConfig.Flag or nil
				SliderConfig.Save      = SliderConfig.Save or false

				local Slider   = {Value = SliderConfig.Default, Save = SliderConfig.Save}
				local Dragging = false

				-- White fill
				local SliderFill = SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 3), {
					Size = UDim2.new(0, 0, 1, 0)
				})

				-- Dark track
				local SliderTrack = SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(26, 26, 26), 0, 3), {
					Size     = UDim2.new(1, -24, 0, 5),
					Position = UDim2.new(0, 12, 0, 40),
					ClipsDescendants = true
				}), {
					Create("UIStroke", {Color = Color3.fromRGB(36, 36, 36), Thickness = 1}),
					SliderFill
				})

				local SliderFrame = SetChildren(SetProps(MakeElement("RoundFrame", CARD_COLOR, 0, 5), {
					Size   = UDim2.new(1, 0, 0, 55),
					Parent = ItemParent
				}), {
					AddThemeObject(SetProps(MakeElement("Label", SliderConfig.Name, 13), {
						Size     = UDim2.new(1, -85, 0, 13),
						Position = UDim2.new(0, 12, 0, 12),
						Font     = Enum.Font.GothamMedium,
						Name     = "Content"
					}), "Text"),
					AddThemeObject(SetProps(MakeElement("Label", tostring(SliderConfig.Default) .. " " .. SliderConfig.ValueName, 12), {
						Size           = UDim2.new(0, 70, 0, 13),
						Position       = UDim2.new(1, -82, 0, 12),
						TextXAlignment = Enum.TextXAlignment.Right,
						Font           = Enum.Font.GothamBold,
						Name           = "ValLabel"
					}), "TextDark"),
					Create("UIStroke", {Color = STROKE_COLOR, Thickness = 1}),
					SliderTrack
				})

				function Slider:Set(Value)
					self.Value = math.clamp(Round(Value, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
					local scale = (self.Value - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min)
					TweenService:Create(SliderFill, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Size = UDim2.fromScale(scale, 1)}):Play()
					SliderFrame.ValLabel.Text = tostring(self.Value) .. " " .. SliderConfig.ValueName
					SliderConfig.Callback(self.Value)
				end

				SliderTrack.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true end
				end)
				SliderTrack.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
				end)
				UserInputService.InputChanged:Connect(function(i)
					if Dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
						local s = math.clamp((i.Position.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
						Slider:Set(SliderConfig.Min + (SliderConfig.Max - SliderConfig.Min) * s)
						SaveCfg(game.GameId)
					end
				end)

				Slider:Set(Slider.Value)
				if SliderConfig.Flag then BlackairLib.Flags[SliderConfig.Flag] = Slider end
				return Slider
			end

			-- ‚ĒÄ‚ĒÄ Dropdown ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

			function ElementFunction:AddDropdown(DropdownConfig)
				DropdownConfig          = DropdownConfig or {}
				DropdownConfig.Name     = DropdownConfig.Name or "Dropdown"
				DropdownConfig.Options  = DropdownConfig.Options or {}
				DropdownConfig.Default  = DropdownConfig.Default or ""
				DropdownConfig.Callback = DropdownConfig.Callback or function() end
				DropdownConfig.Flag     = DropdownConfig.Flag or nil
				DropdownConfig.Save     = DropdownConfig.Save or false

				local Dropdown = {Value = DropdownConfig.Default, Options = DropdownConfig.Options, Buttons = {}, Toggled = false, Type = "Dropdown", Save = DropdownConfig.Save}
				local MaxEl    = 5

				if not table.find(Dropdown.Options, Dropdown.Value) then Dropdown.Value = "..." end

				local DropList = MakeElement("List")

				local DropContainer = SetProps(SetChildren(MakeElement("ScrollFrame", Color3.fromRGB(28, 28, 28), 3), {DropList}), {
					Parent           = ItemParent,
					Position         = UDim2.new(0, 0, 0, 34),
					Size             = UDim2.new(1, 0, 1, -34),
					ClipsDescendants = true
				})

				local Click = SetProps(MakeElement("Button"), {Size = UDim2.new(1, 0, 1, 0)})

				local DropFrame = SetChildren(SetProps(MakeElement("RoundFrame", CARD_COLOR, 0, 5), {
					Size             = UDim2.new(1, 0, 0, 34),
					Parent           = ItemParent,
					ClipsDescendants = true
				}), {
					DropContainer,
					SetProps(SetChildren(MakeElement("TFrame"), {
						AddThemeObject(SetProps(MakeElement("Label", DropdownConfig.Name, 13), {
							Size     = UDim2.new(1, -14, 1, 0),
							Position = UDim2.new(0, 12, 0, 0),
							Font     = Enum.Font.GothamMedium,
							Name     = "Content"
						}), "Text"),
						AddThemeObject(SetProps(MakeElement("Image", "rbxassetid://7072706796"), {
							Size        = UDim2.new(0, 12, 0, 12),
							AnchorPoint = Vector2.new(0, 0.5),
							Position    = UDim2.new(1, -24, 0.5, 0),
							ImageColor3 = Color3.fromRGB(255, 255, 255),
							Name        = "Ico"
						}), "TextDark"),
						AddThemeObject(SetProps(MakeElement("Label", "...", 12), {
							Size           = UDim2.new(1, -40, 1, 0),
							Font           = Enum.Font.Gotham,
							Name           = "Selected",
							TextXAlignment = Enum.TextXAlignment.Right
						}), "TextDark"),
						SetProps(MakeElement("Frame"), {
							Size             = UDim2.new(1, 0, 0, 1),
							Position         = UDim2.new(0, 0, 1, -1),
							Name             = "Line", Visible = false,
							BackgroundColor3 = Color3.fromRGB(34, 34, 34),
							BorderSizePixel  = 0
						}),
						Click
					}), {Size = UDim2.new(1, 0, 0, 34), ClipsDescendants = true, Name = "F"}),
					Create("UIStroke", {Color = STROKE_COLOR, Thickness = 1}),
					MakeElement("Corner")
				})

				AddConnection(DropList:GetPropertyChangedSignal("AbsoluteContentSize"), function()
					DropContainer.CanvasSize = UDim2.new(0, 0, 0, DropList.AbsoluteContentSize.Y)
				end)

				local function AddOptions(Options)
					for _, Option in pairs(Options) do
						local btn = SetProps(SetChildren(MakeElement("Button"), {
							MakeElement("Corner", 0, 4),
							AddThemeObject(SetProps(MakeElement("Label", Option, 12, 0.5), {
								Position = UDim2.new(0, 10, 0, 0),
								Size     = UDim2.new(1, -10, 1, 0),
								Name     = "Title"
							}), "Text")
						}), {
							Parent                 = DropContainer,
							Size                   = UDim2.new(1, 0, 0, 26),
							BackgroundTransparency = 1,
							BackgroundColor3       = Color3.fromRGB(26, 26, 26),
							ClipsDescendants       = true
						})
						AddConnection(btn.MouseButton1Click, function()
							Dropdown:Set(Option)
							SaveCfg(game.GameId)
						end)
						Dropdown.Buttons[Option] = btn
					end
				end

				function Dropdown:Refresh(Options, Delete)
					if Delete then
						for _, v in pairs(Dropdown.Buttons) do v:Destroy() end
						table.clear(Dropdown.Options)
						table.clear(Dropdown.Buttons)
					end
					Dropdown.Options = Options
					AddOptions(Dropdown.Options)
				end

				function Dropdown:Set(Value)
					if not table.find(Dropdown.Options, Value) then
						Dropdown.Value = "..."
						DropFrame.F.Selected.Text = "..."
						for _, v in pairs(Dropdown.Buttons) do
							TweenService:Create(v, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()
							TweenService:Create(v.Title, TweenInfo.new(0.12), {TextTransparency = 0.5}):Play()
						end
						return
					end
					Dropdown.Value = Value
					DropFrame.F.Selected.Text = Value
					for _, v in pairs(Dropdown.Buttons) do
						TweenService:Create(v, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()
						TweenService:Create(v.Title, TweenInfo.new(0.12), {TextTransparency = 0.5}):Play()
					end
					TweenService:Create(Dropdown.Buttons[Value], TweenInfo.new(0.12), {BackgroundTransparency = 0}):Play()
					TweenService:Create(Dropdown.Buttons[Value].Title, TweenInfo.new(0.12), {TextTransparency = 0}):Play()
					DropdownConfig.Callback(Dropdown.Value)
				end

				AddConnection(Click.MouseButton1Click, function()
					Dropdown.Toggled = not Dropdown.Toggled
					DropFrame.F.Line.Visible = Dropdown.Toggled
					TweenService:Create(DropFrame.F.Ico, TweenInfo.new(0.15), {Rotation = Dropdown.Toggled and 180 or 0}):Play()
					local h = #Dropdown.Options > MaxEl and (34 + MaxEl * 26) or (DropList.AbsoluteContentSize.Y + 34)
					TweenService:Create(DropFrame, TweenInfo.new(0.15), {Size = Dropdown.Toggled and UDim2.new(1, 0, 0, h) or UDim2.new(1, 0, 0, 34)}):Play()
				end)

				Dropdown:Refresh(Dropdown.Options, false)
				Dropdown:Set(Dropdown.Value)
				if DropdownConfig.Flag then BlackairLib.Flags[DropdownConfig.Flag] = Dropdown end
				return Dropdown
			end

			-- ‚ĒÄ‚ĒÄ Bind ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

