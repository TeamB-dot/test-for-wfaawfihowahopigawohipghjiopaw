            local TopBar = Instance.new("Frame", {
                Parent = Frame,
                Size = UDim2.new(1, 0, 0, 42),
                BackgroundColor3 = Color3.fromRGB(22, 22, 22),
                BorderSizePixel = 0,
            })
            local Label = MakeElement("Label", Config.Name, 13)
            Label.Font = Enum.Font.GothamSemibold
            Label.TextColor3 = Color3.fromRGB(235, 235, 235)
            Label.Position = UDim2.new(0, 14, 0, 14)
            Label.Size = UDim2.new(1, -60, 0, 14)
            Label.Parent = TopBar

            local ColorBox = Instance.new("Frame", {
                Parent = TopBar,
                Size = UDim2.new(0, 24, 0, 24),
                Position = UDim2.new(1, -34, 0.5, -12),
                AnchorPoint = Vector2.new(1, 0),
                BackgroundColor3 = Config.Default,
                BorderSizePixel = 0,
            })
            MakeElement("Corner", 0, 4).Parent = ColorBox
            Instance.new("UIStroke", {Color = Color3.fromRGB(70, 70, 70), Thickness = 1}).Parent = ColorBox

            local Divider = Instance.new("Frame", {
                Parent = TopBar,
                Size = UDim2.new(1, 0, 0, 1),
                Position = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = Color3.fromRGB(45, 45, 45),
                Visible = false,
            })

            local PickerContainer = Instance.new("Frame", {
                Parent = Frame,
                Size = UDim2.new(1, 0, 0, 100),
                Position = UDim2.new(0, 0, 0, 42),
                BackgroundTransparency = 1,
                Visible = false,
            })

            local SVPicker = Instance.new("ImageLabel", {
                Parent = PickerContainer,
                Size = UDim2.new(1, -44, 1, 0),
                Image = "rbxassetid://4155801252",
                BackgroundTransparency = 1,
            })
            local SVPickerCorner = MakeElement("Corner", 0, 4)
            SVPickerCorner.Parent = SVPicker
            local SVKnob = Instance.new("ImageLabel", {
                Parent = SVPicker,
                Size = UDim2.new(0, 12, 0, 12),
                AnchorPoint = Vector2.new(0.5, 0.5),
                BackgroundTransparency = 1,
                Image = "http://www.roblox.com/asset/?id=4805639000",
            })

            local HuePicker = Instance.new("Frame", {
                Parent = PickerContainer,
                Size = UDim2.new(0, 16, 1, 0),
                Position = UDim2.new(1, -16, 0, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            })
            MakeElement("Corner", 0, 4).Parent = HuePicker
            local HueGradient = Instance.new("UIGradient", {
                Parent = HuePicker,
                Rotation = 270,
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.2, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.4, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.6, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.8, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
                }
            })
            local HueKnob = Instance.new("ImageLabel", {
                Parent = HuePicker,
                Size = UDim2.new(0, 12, 0, 12),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0.5, 0, 0, 0),
                BackgroundTransparency = 1,
                Image = "http://www.roblox.com/asset/?id=4805639000",
            })

            local function UpdatePicker()
                ColorBox.BackgroundColor3 = Color3.fromHSV(H, S, V)
                SVPicker.ImageColor3 = Color3.fromHSV(H, 1, 1)
                SVKnob.Position = UDim2.new(S, 0, 1 - V, 0)
                HueKnob.Position = UDim2.new(0.5, 0, 1 - H, 0)
                ColorObj.Value = ColorBox.BackgroundColor3
                Config.Callback(ColorObj.Value)
                if Config.Save then SaveCfg(game.GameId) end
            end

            local SVInput, HueInput
            SVPicker.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if SVInput then SVInput:Disconnect() end
                    SVInput = RunService.RenderStepped:Connect(function()
                        S = math.clamp((Mouse.X - SVPicker.AbsolutePosition.X) / SVPicker.AbsoluteSize.X, 0, 1)
                        V = 1 - math.clamp((Mouse.Y - SVPicker.AbsolutePosition.Y) / SVPicker.AbsoluteSize.Y, 0, 1)
                        UpdatePicker()
                    end)
                end
            end)
            SVPicker.InputEnded:Connect(function()
                if SVInput then SVInput:Disconnect() end
            end)

            HuePicker.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if HueInput then HueInput:Disconnect() end
                    HueInput = RunService.RenderStepped:Connect(function()
                        H = 1 - math.clamp((Mouse.Y - HuePicker.AbsolutePosition.Y) / HuePicker.AbsoluteSize.Y, 0, 1)
                        UpdatePicker()
                    end)
                end
            end)
            HuePicker.InputEnded:Connect(function()
                if HueInput then HueInput:Disconnect() end
            end)

            local Clicker = Instance.new("TextButton", {
                Parent = TopBar,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
                BackgroundTransparency = 1,
            })
            SetupHover(TopBar, Color3.fromRGB(28, 28, 28), Color3.fromRGB(32, 32, 32))
            Clicker.MouseButton1Up:Connect(function()
                ColorObj.Toggled = not ColorObj.Toggled
                local newHeight = ColorObj.Toggled and 142 or 42
                TweenService:Create(Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1, 0, 0, newHeight)}):Play()
                Divider.Visible = ColorObj.Toggled
                PickerContainer.Visible = ColorObj.Toggled
            end)

            function ColorObj:Set(color)
                H, S, V = Color3.toHSV(color)
                UpdatePicker()
            end
            ColorObj:Set(Config.Default)
            if Config.Flag then BlackairLib.Flags[Config.Flag] = ColorObj end
            return ColorObj
        end

        -- Premium Lock
        if TabConfig.PremiumOnly then
            local Lock = Instance.new("Frame", {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Color3.fromRGB(12, 12, 12),
                BackgroundTransparency = 0.8,
            })
            local LockIcon = MakeElement("Image", "rbxassetid://3610239960")
            LockIcon.Size = UDim2.new(0, 32, 0, 32)
            LockIcon.Position = UDim2.new(0.5, -16, 0.3, 0)
            LockIcon.ImageColor3 = Color3.fromRGB(100, 100, 100)
            LockIcon.Parent = Lock
            local LockText = MakeElement("Label", "Premium Only", 16)
            LockText.Font = Enum.Font.GothamBold
            LockText.TextColor3 = Color3.fromRGB(200, 200, 200)
            LockText.Position = UDim2.new(0.5, -80, 0.45, 0)
            LockText.Size = UDim2.new(0, 160, 0, 20)
            LockText.TextXAlignment = Enum.TextXAlignment.Center
            LockText.Parent = Lock
            local LockSub = MakeElement("Label", "This tab requires BlackAir Premium", 11)
            LockSub.TextColor3 = Color3.fromRGB(120, 120, 120)
            LockSub.Position = UDim2.new(0.5, -120, 0.55, 0)
            LockSub.Size = UDim2.new(0, 240, 0, 16)
            LockSub.TextXAlignment = Enum.TextXAlignment.Center
            LockSub.Parent = Lock
            for _, child in pairs(TabContent:GetChildren()) do child:Destroy() end
        end

        return Elements
    end

    return Tabs
end

function BlackairLib:Destroy()
    Blackair:Destroy()
end

return BlackairLib
