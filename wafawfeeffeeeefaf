				local ToggleKnob = Create("Frame", {
					Size             = UDim2.new(0, 14, 0, 14),
					Position         = UDim2.new(0, 3, 0.5, 0),
					AnchorPoint      = Vector2.new(0, 0.5),
					BackgroundColor3 = Color3.fromRGB(80, 80, 80),
					BorderSizePixel  = 0,
