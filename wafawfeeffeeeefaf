					Size = UDim2.new(1, -36, 0, 13),
					Position = UDim2.new(0, 36, 0, 16),
					TextTransparency = 0.4,
					TextColor3 = Color3.fromRGB(255, 255, 255)
				}), "Text"),
				AddThemeObject(SetProps(MakeElement("Label", "Premium only", 13), {
					Size = UDim2.new(1, -140, 0, 13),
					Position = UDim2.new(0, 140, 0, 110),
					Font = Enum.Font.GothamBold,
					TextColor3 = Color3.fromRGB(255, 255, 255)
				}), "Text"),
				AddThemeObject(SetProps(MakeElement("Label", "This tab is reserved for Blackair Premium. Join the Discord to purchase.", 12), {
					Size = UDim2.new(1, -200, 0, 12),
					Position = UDim2.new(0, 140, 0, 130),
					TextWrapped = true,
					TextTransparency = 0.45
				}), "TextDark")
			})
		end

		return ElementFunction
	end -- MakeTab

	return TabFunction
