function BlackairLib:Init()
	if BlackairLib.SaveCfg then
		pcall(function()
			if isfile(BlackairLib.Folder .. "/" .. game.GameId .. ".txt") then
				LoadCfg(readfile(BlackairLib.Folder .. "/" .. game.GameId .. ".txt"))
				BlackairLib:MakeNotification({
					Name    = "Config loaded",
					Content = "Settings restored for " .. game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
					Time    = 4
				})
			end
		end)
	end
end

