					Toggle.Value = Value
					local knobX  = Value and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
					local pillBg = Value and Color3.fromRGB(220, 220, 220) or Color3.fromRGB(35, 35, 35)
					local knobBg = Value and Color3.fromRGB(10, 10, 10)   or Color3.fromRGB(80, 80, 80)
					TweenService:Create(ToggleKnob,  TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Position         = knobX}):Play()
					TweenService:Create(TogglePill,  TweenInfo.new(0.25, Enum.EasingStyle.Quint), {BackgroundColor3 = pillBg}):Play()
					TweenService:Create(ToggleKnob,  TweenInfo.new(0.25, Enum.EasingStyle.Quint), {BackgroundColor3 = knobBg}):Play()
