-- ─────────────────────────────────────────────────────────────────
-- Config helpers
-- ─────────────────────────────────────────────────────────────────
local function PackColor(c)   return {R=c.R*255, G=c.G*255, B=c.B*255} end
local function UnpackColor(c) return Color3.fromRGB(c.R, c.G, c.B)    end
local function Round(n, f)
	local r = math.floor(n/f + math.sign(n)*0.5)*f
	if r < 0 then r = r + f end
	return r
end

local function LoadCfg(data)
	local ok, decoded = pcall(function() return HttpService:JSONDecode(data) end)
	if not ok then return end
	for k,v in pairs(decoded) do
		if BlackairLib.Flags[k] then
			task.spawn(function()
				if BlackairLib.Flags[k].Type == "Colorpicker" then
					BlackairLib.Flags[k]:Set(UnpackColor(v))
				else
					BlackairLib.Flags[k]:Set(v)
				end
			end)
		end
	end
end

local function SaveFlag(name)
	if not BlackairLib.SaveCfg then return end
	local data = {}
	for k,v in pairs(BlackairLib.Flags) do
		if v.Save then
			data[k] = v.Type == "Colorpicker" and PackColor(v.Value) or v.Value
		end
	end
	pcall(function()
		writefile(BlackairLib.Folder.."/"..name..".txt", HttpService:JSONEncode(data))
	end)
end

