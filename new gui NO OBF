		local function SetActive(on)
			if on then
				Strip.BackgroundTransparency    = 0
				TabIco.ImageColor3              = C.White
				TabLabel.TextColor3             = C.White
				TabLabel.TextTransparency       = 0
				TabLabel.Font                   = Enum.Font.GothamBold
			else
				Strip.BackgroundTransparency    = 1
				TabIco.ImageColor3              = C.Dim
				TabLabel.TextColor3             = C.Muted
				TabLabel.TextTransparency       = 0.4
				TabLabel.Font                   = Enum.Font.GothamSemibold
			end
		end

		if FirstTab then
			FirstTab = false
			SetActive(true)
			Content.Visible = true
		end

		Conn(TabBtn.MouseButton1Click, function()
			-- deactivate all
			for _, c in next, TabScroll:GetChildren() do
				if c:IsA("TextButton") then
					c.Lbl.TextColor3      = C.Muted
					c.Lbl.TextTransparency= 0.4
					c.Lbl.Font            = Enum.Font.GothamSemibold
					c.Ico.ImageColor3     = C.Dim
					c.Strip.BackgroundTransparency = 1
				end
			end
			for _, w in next, Win:GetChildren() do
				if w.Name == "TabContent" then w.Visible = false end
			end
			SetActive(true)
			Content.Visible = true
		end)

