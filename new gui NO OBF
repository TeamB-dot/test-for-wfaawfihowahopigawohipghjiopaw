-- ── Connection helper ─────────────────────────────────────────────
function BlackairLib:IsRunning()
	return Root.Parent == (gethui and gethui() or game.CoreGui)
end
local function Conn(signal, fn)
	if not BlackairLib:IsRunning() then return end
	local c = signal:Connect(fn)
	table.insert(BlackairLib.Connections, c)
	return c
end
task.spawn(function()
	while BlackairLib:IsRunning() do task.wait() end
	for _, c in next, BlackairLib.Connections do c:Disconnect() end
end)

-- ── Drag ──────────────────────────────────────────────────────────
local function MakeDraggable(handle, frame)
	pcall(function()
		local drag, input, mpos, fpos = false
		handle.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 then
				drag = true; mpos = i.Position; fpos = frame.Position
			end
		end)
		handle.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
		end)
		handle.InputChanged:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.MouseMovement then input = i end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if i == input and drag then
				local d = i.Position - mpos
				Tween(frame, 0.38, {
					Position = UDim2.new(
						fpos.X.Scale, fpos.X.Offset + d.X,
						fpos.Y.Scale, fpos.Y.Offset + d.Y
					)
				})
			end
		end)
	end)
end

-- ── Instance factory ──────────────────────────────────────────────
local function New(class, props, children)
	local o = Instance.new(class)
	for k,v in next, props or {} do o[k] = v end
	for _,v in next, children or {} do v.Parent = o end
	return o
end
local function Corner(r)   return New("UICorner",    {CornerRadius = UDim.new(0, r or 6)}) end
local function Stroke(c,t) return New("UIStroke",    {Color = c or C.Border, Thickness = t or 1}) end
local function List(pad)   return New("UIListLayout",{SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, pad or 0)}) end
local function Pad(b,l,r,t)
	return New("UIPadding",{
		PaddingBottom = UDim.new(0, b or 0),
		PaddingLeft   = UDim.new(0, l or 0),
		PaddingRight  = UDim.new(0, r or 0),
		PaddingTop    = UDim.new(0, t or 0),
	})
end

