function BlackairLib:MakeNotification(cfg)
	task.spawn(function()
		local name    = cfg.Name    or "Notification"
		local content = cfg.Content or ""
		local time    = cfg.Time    or 5
		local icon    = cfg.Image   or "rbxassetid://4384403532"

		-- wrapper (drives slide)
		local Wrap = New("Frame", {
			Size               = UDim2.new(1, 0, 0, 0),
			AutomaticSize      = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1,
			ClipsDescendants   = false,
			Parent             = NotifHolder,
		})

		-- card
		local Card_ = New("Frame", {
			Size             = UDim2.new(1, 0, 0, 0),
			AutomaticSize    = Enum.AutomaticSize.Y,
			BackgroundColor3 = C.Surface,
			BorderSizePixel  = 0,
			Position         = UDim2.new(1, 16, 0, 0),
			Parent           = Wrap,
		}, {Corner(8), Stroke(C.Border, 1)})

		-- signature: white top-light on notification
		New("Frame", {
			Size             = UDim2.new(1, -16, 0, 1),
			Position         = UDim2.new(0, 8, 0, 0),
			BackgroundColor3 = C.White,
			BackgroundTransparency = 0.6,
			BorderSizePixel  = 0,
			ZIndex           = 10,
			Parent           = Card_,
		})

		-- inner padding frame
		local Inner = New("Frame", {
			Size          = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1,
			Parent        = Card_,
		}, {Pad(12, 14, 14, 14)})

		-- icon
		New("ImageLabel", {
			Size        = UDim2.new(0, 14, 0, 14),
			Position    = UDim2.new(0, 0, 0, 1),
			Image       = icon,
			ImageColor3 = C.Muted,
			BackgroundTransparency = 1,
			Parent      = Inner,
		})

		-- title
		local TitleL = Label(name, 13, C.White, Enum.Font.GothamBold)
		TitleL.Size     = UDim2.new(1, -20, 0, 14)
		TitleL.Position = UDim2.new(0, 20, 0, 0)
		TitleL.Parent   = Inner

		-- body
		local BodyL = Label(content, 12, C.Muted, Enum.Font.Gotham)
		BodyL.Size          = UDim2.new(1, 0, 0, 0)
		BodyL.Position      = UDim2.new(0, 0, 0, 20)
		BodyL.AutomaticSize = Enum.AutomaticSize.Y
		BodyL.TextWrapped   = true
		BodyL.Parent        = Inner

		-- slide in
		Tween(Card_, 0.4, {Position = UDim2.new(0, 0, 0, 0)})
		task.wait(math.max(0.5, time - 0.8))

		-- fade + slide out
		TweenIn(Card_, 0.3, {BackgroundTransparency = 0.7})
		task.wait(0.2)
		TweenIn(Card_, 0.45, {Position = UDim2.new(1, 16, 0, 0)})
		task.wait(0.5)
		Wrap:Destroy()
	end)
end

-- ═════════════════════════════════════════════════════════════════
--  INIT
-- ═════════════════════════════════════════════════════════════════
function BlackairLib:Init()
	if self.SaveCfg then
		pcall(function()
			local path = self.Folder.."/"..game.GameId..".txt"
			if isfile(path) then
				LoadCfg(readfile(path))
				self:MakeNotification({
					Name    = "Config loaded",
					Content = "Settings restored · "..game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
					Time    = 4,
				})
			end
		end)
	end
end

