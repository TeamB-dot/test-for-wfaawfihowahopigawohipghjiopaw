				TopLight(outer)

				-- header row
				local hdr = New("Frame",{
					Size             = UDim2.new(1,0,0,34),
					BackgroundTransparency = 1,
					ClipsDescendants = true,
					Parent           = outer,
				})

				local hdrBtn = ClickBtn(); hdrBtn.Parent = hdr

				local hdrLbl = Label(dcfg.Name, 13, C.Text, Enum.Font.GothamSemibold)
