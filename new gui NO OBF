				hdrLbl.Position = UDim2.new(0,14,0,0)
				hdrLbl.Parent   = hdr

				local selLbl = Label("···", 12, C.Muted, Enum.Font.Gotham)
				selLbl.Size           = UDim2.new(0.4,0,1,0)
				selLbl.Position       = UDim2.new(0.58,0,0,0)
				selLbl.TextXAlignment = Enum.TextXAlignment.Right
				selLbl.Name           = "Sel"
				selLbl.Parent         = hdr

				local arrow = New("ImageLabel",{
					Size        = UDim2.new(0,12,0,12),
					Position    = UDim2.new(1,-22,0.5,-6),
					Image       = "rbxassetid://7072706796",
					ImageColor3 = C.Dim,
					BackgroundTransparency=1,
					Parent      = hdr,
				})

				-- divider shown when open
				local divLine = New("Frame",{
					Size             = UDim2.new(1,0,0,1),
					Position         = UDim2.new(0,0,0,33),
					BackgroundColor3 = C.Border,
					BorderSizePixel  = 0,
					Visible          = false,
					Parent           = outer,
				})

				-- option list
				local optScroll = ScrollFrame(2)
				optScroll.Size     = UDim2.new(1,0,1,-34)
				optScroll.Position = UDim2.new(0,0,0,34)
				optScroll.Parent   = outer
				local optList = List(1)
				optList.Parent = optScroll
				Pad(4,6,6,4).Parent = optScroll
				Conn(optList:GetPropertyChangedSignal("AbsoluteContentSize"), function()
					optScroll.CanvasSize = UDim2.new(0,0,0, optList.AbsoluteContentSize.Y + 8)
				end)

				local function AddOpts(opts)
					for _, opt in pairs(opts) do
						local ob = New("TextButton",{
							Size             = UDim2.new(1,0,0,26),
							BackgroundColor3 = C.Raised,
							BackgroundTransparency = 1,
							Text             = "",
							AutoButtonColor  = false,
							Parent           = optScroll,
						},{Corner(5)})

						local ol = Label(opt, 12, C.Muted, Enum.Font.GothamSemibold)
						ol.Size     = UDim2.new(1,-20,1,0)
						ol.Position = UDim2.new(0,10,0,0)
						ol.Name     = "Lbl"
						ol.Parent   = ob

						Conn(ob.MouseButton1Click, function()
							DD:Set(opt)
							SaveFlag(game.GameId)
						end)
						DD.Buttons[opt] = ob
					end
				end

				function DD:Refresh(opts, clear)
					if clear then
						for _,v in pairs(self.Buttons) do v:Destroy() end
						table.clear(self.Options)
						table.clear(self.Buttons)
					end
					self.Options = opts
					AddOpts(opts)
				end

				function DD:Set(v)
					if not table.find(self.Options, v) then
						self.Value = "···"
						hdr.Sel.Text = "···"
						for _,b in pairs(self.Buttons) do
							Tween(b, 0.1, {BackgroundTransparency=1})
							Tween(b.Lbl, 0.1, {TextTransparency=0.4})
						end
						return
					end
					self.Value       = v
					hdr.Sel.Text     = v
					hdr.Sel.TextColor3 = C.Text
					for _,b in pairs(self.Buttons) do
						Tween(b, 0.1, {BackgroundTransparency=1})
						Tween(b.Lbl, 0.1, {TextTransparency=0.4, TextColor3=C.Muted})
					end
					Tween(self.Buttons[v], 0.1, {BackgroundTransparency=0})
					Tween(self.Buttons[v].Lbl, 0.1, {TextTransparency=0, TextColor3=C.White})
					dcfg.Callback(self.Value)
				end

				Conn(hdrBtn.MouseButton1Click, function()
					DD.Toggled = not DD.Toggled
					divLine.Visible = DD.Toggled
					Tween(arrow, 0.15, {Rotation = DD.Toggled and 180 or 0})
					local h = DD.Toggled
						and (34 + math.min(#DD.Options, MaxVisible)*27 + 8)
						or  34
					Tween(outer, 0.15, {Size = UDim2.new(1,0,0,h)})
				end)

				DD:Refresh(DD.Options, false)
				DD:Set(DD.Value)
				if dcfg.Flag then BlackairLib.Flags[dcfg.Flag] = DD end
				return DD
			end

			-- BIND ─────────────────────────────────────────────────
			function EF:AddBind(bcfg)
				bcfg          = bcfg or {}
				bcfg.Name     = bcfg.Name     or "Bind"
				bcfg.Default  = bcfg.Default  or Enum.KeyCode.Unknown
				bcfg.Hold     = bcfg.Hold     or false
				bcfg.Callback = bcfg.Callback or function() end
				bcfg.Flag     = bcfg.Flag     or nil
				bcfg.Save     = bcfg.Save     or false

				local Bind    = {Value=nil, Binding=false, Type="Bind", Save=bcfg.Save}
				local Holding = false
				local f       = Card(host, 36)
				local btn     = ClickBtn(); btn.Parent = f

				local lbl = Label(bcfg.Name, 13, C.Text, Enum.Font.GothamSemibold)
				lbl.Size     = UDim2.new(1,-80,1,0)
				lbl.Position = UDim2.new(0,14,0,0)
				lbl.Parent   = f

				local box = New("Frame",{
					Size             = UDim2.new(0,28,0,20),
					Position         = UDim2.new(1,-12,0.5,0),
					AnchorPoint      = Vector2.new(1,0.5),
					BackgroundColor3 = C.Raised,
					BorderSizePixel  = 0,
					Parent           = f,
				},{Corner(4), Stroke(C.Border,1)})

				local boxLbl = Label("", 11, C.Text, Enum.Font.GothamBold)
				boxLbl.Size           = UDim2.new(1,0,1,0)
				boxLbl.TextXAlignment = Enum.TextXAlignment.Center
				boxLbl.Name           = "Val"
				boxLbl.Parent         = box

				Conn(boxLbl:GetPropertyChangedSignal("Text"), function()
					Tween(box, 0.18, {Size = UDim2.new(0, boxLbl.TextBounds.X+14, 0, 20)})
				end)

				Conn(btn.InputEnded, function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 and not Bind.Binding then
						Bind.Binding = true
						box.Val.Text = "···"
					end
				end)

				Conn(UserInputService.InputBegan, function(i)
					if UserInputService:GetFocusedTextBox() then return end
					if (i.KeyCode.Name == Bind.Value or i.UserInputType.Name == Bind.Value) and not Bind.Binding then
						if bcfg.Hold then Holding = true; bcfg.Callback(true)
						else bcfg.Callback() end
					elseif Bind.Binding then
						local key
						pcall(function() if not HasKey(BlacklistedKeys, i.KeyCode)    then key = i.KeyCode        end end)
						pcall(function() if HasKey(WhitelistedMouse, i.UserInputType) and not key then key = i.UserInputType end end)
						Bind:Set(key or Bind.Value)
						SaveFlag(game.GameId)
					end
				end)
				Conn(UserInputService.InputEnded, function(i)
					if (i.KeyCode.Name == Bind.Value or i.UserInputType.Name == Bind.Value) then
						if bcfg.Hold and Holding then Holding = false; bcfg.Callback(false) end
					end
				end)

				Conn(btn.MouseEnter,       function() HoverOn(f) end)
				Conn(btn.MouseLeave,       function() HoverOff(f) end)
				Conn(btn.MouseButton1Down, function() PressDown(f) end)
				Conn(btn.MouseButton1Up,   function() HoverOn(f) end)

				function Bind:Set(k)
					self.Binding = false
					self.Value   = k or self.Value
					self.Value   = (type(self.Value) == "userdata" and self.Value.Name) or self.Value
					box.Val.Text = self.Value or "—"
				end
				Bind:Set(bcfg.Default)
				if bcfg.Flag then BlackairLib.Flags[bcfg.Flag] = Bind end
				return Bind
			end

			-- TEXTBOX ──────────────────────────────────────────────
			function EF:AddTextbox(tcfg)
				tcfg               = tcfg or {}
				tcfg.Name          = tcfg.Name          or "Textbox"
				tcfg.Default       = tcfg.Default       or ""
				tcfg.TextDisappear = tcfg.TextDisappear or false
				tcfg.Callback      = tcfg.Callback      or function() end

				local f   = Card(host, 36)
				local btn = ClickBtn(); btn.Parent = f

				local lbl = Label(tcfg.Name, 13, C.Text, Enum.Font.GothamSemibold)
				lbl.Size     = UDim2.new(1,-90,1,0)
				lbl.Position = UDim2.new(0,14,0,0)
				lbl.Parent   = f

				local tbox_wrap = New("Frame",{
					Size             = UDim2.new(0,28,0,20),
					Position         = UDim2.new(1,-12,0.5,0),
					AnchorPoint      = Vector2.new(1,0.5),
					BackgroundColor3 = C.Raised,
					BorderSizePixel  = 0,
					Parent           = f,
				},{Corner(4), Stroke(C.Border,1)})

				local tb = New("TextBox",{
					Size                 = UDim2.new(1,0,1,0),
					BackgroundTransparency=1,
					TextColor3           = C.Text,
					PlaceholderColor3    = C.Dim,
					PlaceholderText      = "···",
					Font                 = Enum.Font.GothamSemibold,
					TextXAlignment       = Enum.TextXAlignment.Center,
					TextSize             = 12,
					ClearTextOnFocus     = false,
					Text                 = tcfg.Default,
					Parent               = tbox_wrap,
				})

				Conn(tb:GetPropertyChangedSignal("Text"), function()
					Tween(tbox_wrap, 0.18, {Size=UDim2.new(0, math.max(28, tb.TextBounds.X+14), 0, 20)})
				end)
				Conn(tb.FocusLost, function()
					tcfg.Callback(tb.Text)
					if tcfg.TextDisappear then tb.Text = "" end
				end)
				Conn(btn.MouseEnter,       function() HoverOn(f) end)
				Conn(btn.MouseLeave,       function() HoverOff(f) end)
				Conn(btn.MouseButton1Down, function() PressDown(f) end)
				Conn(btn.MouseButton1Up,   function() HoverOn(f); tb:CaptureFocus() end)
			end

			-- COLORPICKER ──────────────────────────────────────────
			function EF:AddColorpicker(ccfg)
				ccfg          = ccfg or {}
				ccfg.Name     = ccfg.Name     or "Color"
				ccfg.Default  = ccfg.Default  or Color3.fromRGB(255,255,255)
				ccfg.Callback = ccfg.Callback or function() end
				ccfg.Flag     = ccfg.Flag     or nil
				ccfg.Save     = ccfg.Save     or false

				local ColorH, ColorS, ColorV = Color3.toHSV(ccfg.Default)
				local CP = {Value=ccfg.Default, Toggled=false, Type="Colorpicker", Save=ccfg.Save}

				local outer = New("Frame",{
					Size             = UDim2.new(1,0,0,34),
					BackgroundColor3 = C.Raised,
					BorderSizePixel  = 0,
					ClipsDescendants = true,
					Parent           = host,
				},{Corner(7), Stroke(C.Border,1)})
				TopLight(outer)

				local hdr = New("Frame",{
					Size = UDim2.new(1,0,0,34),
					BackgroundTransparency=1,
					ClipsDescendants=true,
					Parent=outer,
				})
				local hdrBtn = ClickBtn(); hdrBtn.Parent = hdr

				local hdrLbl = Label(ccfg.Name, 13, C.Text, Enum.Font.GothamSemibold)
				hdrLbl.Size = UDim2.new(1,-46,1,0); hdrLbl.Position = UDim2.new(0,14,0,0)
				hdrLbl.Parent = hdr

				local preview = New("Frame",{
					Size             = UDim2.new(0,20,0,20),
					Position         = UDim2.new(1,-12,0.5,0),
					AnchorPoint      = Vector2.new(1,0.5),
					BackgroundColor3 = ccfg.Default,
					BorderSizePixel  = 0,
					Parent           = hdr,
				},{Corner(4), Stroke(C.Border,1)})

				-- picker panel
				local panel = New("Frame",{
					Size             = UDim2.new(1,0,0,110),
					Position         = UDim2.new(0,0,0,34),
					BackgroundTransparency=1,
					Parent           = outer,
				},{Pad(10,12,12,10)})

				local colorBox = New("ImageLabel",{
					Size  = UDim2.new(1,-24,1,0),
					Image = "rbxassetid://4155801252",
					BackgroundColor3 = Color3.fromHSV(ColorH,1,1),
					Parent = panel,
				},{Corner(4)})
				local colorSel = New("ImageLabel",{
					Size  = UDim2.new(0,14,0,14),
					AnchorPoint = Vector2.new(0.5,0.5),
					Position = UDim2.new(ColorS,0,1-ColorV,0),
					Image = "http://www.roblox.com/asset/?id=4805639000",
					BackgroundTransparency=1,
					Parent = colorBox,
				})

				local hueBar = New("Frame",{
					Size     = UDim2.new(0,14,1,0),
					Position = UDim2.new(1,-14,0,0),
					Parent   = panel,
				},{
					Corner(4),
					New("UIGradient",{
						Rotation = 270,
						Color    = ColorSequence.new{
							ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255,0,4)),
							ColorSequenceKeypoint.new(0.20, Color3.fromRGB(234,255,0)),
							ColorSequenceKeypoint.new(0.40, Color3.fromRGB(21,255,0)),
							ColorSequenceKeypoint.new(0.60, Color3.fromRGB(0,255,255)),
							ColorSequenceKeypoint.new(0.80, Color3.fromRGB(0,17,255)),
							ColorSequenceKeypoint.new(0.90, Color3.fromRGB(255,0,251)),
							ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255,0,4)),
						}
					})
				})
				local hueSel = New("ImageLabel",{
					Size  = UDim2.new(0,14,0,14),
					AnchorPoint = Vector2.new(0.5,0.5),
					Position = UDim2.new(0.5,0, 1-ColorH,0),
					Image = "http://www.roblox.com/asset/?id=4805639000",
					BackgroundTransparency=1,
					Parent = hueBar,
				})

				local function UpdateCP()
					local col = Color3.fromHSV(ColorH, ColorS, ColorV)
					preview.BackgroundColor3  = col
					colorBox.BackgroundColor3 = Color3.fromHSV(ColorH,1,1)
					CP.Value = col
					ccfg.Callback(col)
					SaveFlag(game.GameId)
				end

				local ColConn, HueConn
				Conn(colorBox.InputBegan, function(i)
					if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
					if ColConn then ColConn:Disconnect() end
					ColConn = Conn(RunService.RenderStepped, function()
						ColorS = math.clamp((Mouse.X - colorBox.AbsolutePosition.X)/colorBox.AbsoluteSize.X, 0,1)
						ColorV = 1-math.clamp((Mouse.Y - colorBox.AbsolutePosition.Y)/colorBox.AbsoluteSize.Y, 0,1)
						colorSel.Position = UDim2.new(ColorS,0,1-ColorV,0)
						UpdateCP()
					end)
				end)
				Conn(colorBox.InputEnded, function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 and ColConn then ColConn:Disconnect() end
				end)
				Conn(hueBar.InputBegan, function(i)
					if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
					if HueConn then HueConn:Disconnect() end
					HueConn = Conn(RunService.RenderStepped, function()
						local y = math.clamp((Mouse.Y - hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y, 0,1)
						hueSel.Position = UDim2.new(0.5,0,y,0)
						ColorH = 1-y
						UpdateCP()
					end)
				end)
				Conn(hueBar.InputEnded, function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 and HueConn then HueConn:Disconnect() end
				end)

				Conn(hdrBtn.MouseButton1Click, function()
					CP.Toggled = not CP.Toggled
					Tween(outer, 0.15, {Size = UDim2.new(1,0,0, CP.Toggled and 144 or 34)})
				end)

				function CP:Set(v)
					self.Value = v
					ColorH, ColorS, ColorV = Color3.toHSV(v)
					preview.BackgroundColor3 = v
					colorBox.BackgroundColor3 = Color3.fromHSV(ColorH,1,1)
					colorSel.Position = UDim2.new(ColorS,0,1-ColorV,0)
					hueSel.Position   = UDim2.new(0.5,0,1-ColorH,0)
					ccfg.Callback(v)
				end

				CP:Set(CP.Value)
				if ccfg.Flag then BlackairLib.Flags[ccfg.Flag] = CP end
				return CP
			end

			return EF
		end -- BuildElements

		-- ── Section wrapper ───────────────────────────────────────
		local RootEF = {}

		function RootEF:AddSection(scfg)
			scfg      = scfg or {}
			scfg.Name = scfg.Name or "Section"

			local sec = New("Frame",{
				Size             = UDim2.new(1,0,0,22),
				BackgroundTransparency=1,
				Parent           = Content,
			})

			local secLbl = Label(scfg.Name:upper(), 10, C.Dim, Enum.Font.GothamBold)
			secLbl.Size     = UDim2.new(1,0,0,10)
			secLbl.Position = UDim2.new(0,2,0,4)
			secLbl.TextTransparency = 0
			secLbl.Parent   = sec

			-- thin line after label
			New("Frame",{
				Size             = UDim2.new(1,0,0,1),
				Position         = UDim2.new(0,0,0,18),
				BackgroundColor3 = C.Border,
				BorderSizePixel  = 0,
				Parent           = sec,
			})

			local holder = New("Frame",{
				Size             = UDim2.new(1,0,0,0),
				Position         = UDim2.new(0,0,0,24),
				BackgroundTransparency=1,
				Name             = "H",
				Parent           = sec,
			},{List(6)})

			Conn(holder.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				holder.Size = UDim2.new(1,0,0, holder.UIListLayout.AbsoluteContentSize.Y)
				sec.Size    = UDim2.new(1,0,0, holder.UIListLayout.AbsoluteContentSize.Y + 30)
			end)

			local SF = {}
			for k,v in next, BuildElements(holder) do SF[k] = v end
			return SF
		end

		for k,v in next, BuildElements(Content) do RootEF[k] = v end

		-- PremiumOnly gate
		if tabCfg.PremiumOnly then
			for k in next, RootEF do RootEF[k] = function() end end
			Content:ClearAllChildren()
			local gate = New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Parent=Content})
			local gl = Label("Premium Only", 13, C.Muted, Enum.Font.GothamBold)
			gl.Size=UDim2.new(1,-28,0,13); gl.Position=UDim2.new(0,14,0,14); gl.Parent=gate
			local gl2 = Label("This tab requires Blackair Premium.", 12, C.Dim, Enum.Font.Gotham)
			gl2.Size=UDim2.new(1,-28,0,0); gl2.Position=UDim2.new(0,14,0,32)
			gl2.AutomaticSize=Enum.AutomaticSize.Y; gl2.TextWrapped=true; gl2.Parent=gate
		end

		return RootEF
	end -- MakeTab

	return TabAPI
end -- MakeWindow

function BlackairLib:Destroy()
	Root:Destroy()
end

return BlackairLib
