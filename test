function Library:MakeNotification(data)
    task.spawn(function()
        local Title = data.Name or "Notification"
        local Content = data.Content or ""
        local IconID = data.Image or ""
        local Duration = data.Time or 5

        local NotifFrame = Instance.new("Frame")
        NotifFrame.BackgroundTransparency = 1
        NotifFrame.Size = UDim2.new(1, 0, 0, 0)
        NotifFrame.AutomaticSize = Enum.AutomaticSize.Y
        NotifFrame.Parent = NotificationHolder

        local Background = Instance.new("Frame")
        Background.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        Background.Position = UDim2.new(1, 10, 0, 0)
        Background.Size = UDim2.new(1, 0, 0, 0)
        Background.AutomaticSize = Enum.AutomaticSize.Y
        Background.Parent = NotifFrame

        local Corner = Instance.new("UICorner", Background)
        Corner.CornerRadius = UDim.new(0, 10)

        local Stroke = Instance.new("UIStroke", Background)
        Stroke.Color = Color3.fromRGB(93, 93, 93)
        Stroke.Thickness = 1.2

        local Padding = Instance.new("UIPadding", Background)
        Padding.PaddingBottom = UDim.new(0, 12)
        Padding.PaddingTop = UDim.new(0, 12)
        Padding.PaddingLeft = UDim.new(0, 12)
        Padding.PaddingRight = UDim.new(0, 12)

        local Icon = Instance.new("ImageLabel", Background)
        Icon.BackgroundTransparency = 1
        Icon.Image = IconID
        Icon.Size = UDim2.new(0, 20, 0, 20)

        local TitleLabel = Instance.new("TextLabel", Background)
        TitleLabel.Text = Title
        TitleLabel.Size = UDim2.new(1, -30, 0, 20)
        TitleLabel.Position = UDim2.new(0, 30, 0, 0)
        TitleLabel.Font = Enum.Font.FredokaOne
        TitleLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
        TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
        TitleLabel.BackgroundTransparency = 1

        local ContentLabel = Instance.new("TextLabel", Background)
        ContentLabel.Text = Content
        ContentLabel.Size = UDim2.new(1, 0, 0, 0)
        ContentLabel.Position = UDim2.new(0, 0, 0, 25)
        ContentLabel.AutomaticSize = Enum.AutomaticSize.Y
        ContentLabel.Font = Enum.Font.FredokaOne
        ContentLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
        ContentLabel.TextWrapped = true
        ContentLabel.TextXAlignment = Enum.TextXAlignment.Left
        ContentLabel.BackgroundTransparency = 1

        TweenService:Create(Background, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 0, 0)}):Play()
        
        task.wait(Duration)

        TweenService:Create(Icon, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {ImageTransparency = 1}):Play()
        TweenService:Create(Background, TweenInfo.new(0.8, Enum.EasingStyle.Quint), {BackgroundTransparency = 0.6}):Play()
        TweenService:Create(Stroke, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Transparency = 0.9}):Play()
        
        task.wait(0.3)
        Background:TweenPosition(UDim2.new(1, 20, 0, 0), "In", "Quint", 0.8, true)
        task.wait(1.35)
        NotifFrame:Destroy()
    end)
end

function Library:Destroy()
